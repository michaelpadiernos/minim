    "editorSuggestWidget.selectedBackground": "#040404FF",
    "editorWidget.background": "#000000FF",
    "editorWidget.border": "#00000000",
    "editorWidget.foreground": "#FFFFFFFF",
    "focusBorder": "#00000000",
    "menu.background": "#010101EE",
    "menu.separatorBackground": "#000000FF",
    "menu.separatorForeground": "#000000FF",
    "minimap.background": "#00000000",
    "minimap.border": "#00000000",
