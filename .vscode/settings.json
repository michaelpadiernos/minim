    "commandCenter.background": "#000000FF",
    "commandCenter.border": "#00000000",
    "commandCenter.foreground": "#EFE10088",
    "editor.lineHighlightBackground": "#20202055",
    "editor.lineHighlightBorder": "#20202000",
    "editorGroupHeader.border": "#000000FF",
    "editorHoverWidget.background": "#040404DD",
    "editorHoverWidget.border": "#040404DD",
    "editorHoverWidget.foreground": "#FFFFFFFF",
    "editorOverviewRuler.border": "#00000000",
    "editorSuggestWidget.background": "#040404FF",
