{#
/**
 * @file
 * Template for rendering textfield input elements.
 *
 * This template extends the base input template to provide specialized styling
 * and behavior for single-line text input fields. It inherits all functionality
 * from the parent input template while maintaining consistency with the design
 * system.
 *
 * Variables:
 *   - attributes: HTML attributes object for the input element.
 *   - value: The current value of the input field.
 *   - type: The input type (typically "text").
 *   - name: The name attribute of the input element.
 *   - id: The unique identifier for the input element.
 *   - required: Boolean indicating if the field is required.
 *   - disabled: Boolean indicating if the field is disabled.
 *   - placeholder: Placeholder text displayed when the field is empty.
 *
 * @ingroup templates
 *
 * @see input.html.twig
 */
#}

{% extends '@atoms/input/input.html.twig' %}

{% block input %}

  {%
    set otp_classes = [
      'form--one-time-password',
    ]
  %}

  <input{{ attributes.addClass(otp_classes) }} />{{ children }}

{% endblock input %}
